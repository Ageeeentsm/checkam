{
  "framework": null,
  "outputDirectory": "public",

  "functions": {
    "api/search.js": {
      "runtime": "nodejs@18.x"
    },
    "api/chat.js": {
      "runtime": "nodejs@18.x"
    }
  },

  "rewrites": [
    { "source": "/api/search", "destination": "/api/search" },
    { "source": "/api/chat",   "destination": "/api/chat" },
    { "source": "/(.*)",       "destination": "/index.html" }
  ]
}
